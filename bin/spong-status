#!/usr/bin/env python3
"""SPONG manual status update tool."""

import argparse
import sys
import time

sys.path.insert(0, "/usr/local/spong")
from spong import config
from spong.status_sender import send_status, send_event, send_page


def main():
    parser = argparse.ArgumentParser(description="Send manual status update to SPONG server")
    parser.add_argument("--config", default=None)
    parser.add_argument("--cmd", choices=["status", "event", "page"],
                        default="status", help="Message type")
    parser.add_argument("--host", required=True)
    parser.add_argument("--service", required=True)
    parser.add_argument("--color", required=True,
                        choices=["green", "yellow", "red", "purple", "clear"])
    parser.add_argument("--summary", required=True)
    parser.add_argument("--message", default="")
    parser.add_argument("--file", help="Read message body from file")
    parser.add_argument("--ttl", type=int, default=0,
                        help="Time-to-live in seconds (status only)")
    args = parser.parse_args()

    config.load_all(config_file=args.config)

    message = args.message
    if args.file:
        with open(args.file) as f:
            message = f.read()

    if args.cmd == "status":
        send_status(args.host, args.service, args.color,
                    args.summary, message, ttl=args.ttl)
    elif args.cmd == "event":
        send_event(args.host, args.service, args.color, args.summary, message)
    elif args.cmd == "page":
        send_page(args.host, args.service, args.color, args.summary, message)

    print(f"Sent {args.cmd}: {args.host}/{args.service} = {args.color}: {args.summary}")


if __name__ == "__main__":
    main()
